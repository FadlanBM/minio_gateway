# ============================================
# Konfigurasi untuk Docker Compose & Local Dev
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MinIO Configuration
# Untuk local dev (non-Docker): isi dengan IP/hostname MinIO
# Untuk Docker Compose: otomatis di-override ke "minio" (service name)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false

# Credentials (ubah sesuai kebutuhan)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Default bucket
MINIO_DEFAULT_BUCKET=promilku
